{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.extratoast.com/round3/vault-dynamic-secrets.schema.json",
  "title": "ExtraToast Round 3 Vault Dynamic Secret Input Skeleton",
  "description": "Design-first input schema for Vault auth, KV, transit, database, RabbitMQ, VSO, and service-consumer coordination. This schema does not generate policies, scripts, or manifests.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "vault"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "vault": {
      "$ref": "#/$defs/vault"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "vaultPath": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]*$"
    },
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(s|m|h|d)$"
    },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["auth", "kv", "transit", "database", "rabbitmq", "vso", "service_consumers", "validation_fixtures"],
      "properties": {
        "auth": {
          "$ref": "#/$defs/auth"
        },
        "kv": {
          "$ref": "#/$defs/kv"
        },
        "transit": {
          "$ref": "#/$defs/transit"
        },
        "database": {
          "$ref": "#/$defs/database"
        },
        "rabbitmq": {
          "$ref": "#/$defs/rabbitmq"
        },
        "vso": {
          "$ref": "#/$defs/vso"
        },
        "service_consumers": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/serviceConsumer"
          }
        },
        "validation_fixtures": {
          "$ref": "#/$defs/validationFixtures"
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kubernetes"],
      "properties": {
        "kubernetes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mount", "roles"],
          "properties": {
            "mount": {
              "$ref": "#/$defs/identifier"
            },
            "roles": {
              "type": "object",
              "propertyNames": {
                "$ref": "#/$defs/identifier"
              },
              "additionalProperties": {
                "$ref": "#/$defs/kubernetesRole"
              }
            }
          }
        }
      }
    },
    "kubernetesRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bound_service_accounts", "policies"],
      "properties": {
        "bound_service_accounts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/serviceAccount"
          }
        },
        "policies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "audiences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "ttl": {
          "$ref": "#/$defs/duration"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "namespace"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "namespace": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "kv": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount", "paths"],
      "properties": {
        "mount": {
          "$ref": "#/$defs/identifier"
        },
        "paths": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/kvPath"
          }
        }
      }
    },
    "kvPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "fields"],
      "properties": {
        "path": {
          "$ref": "#/$defs/vaultPath"
        },
        "fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "owner": {
          "$ref": "#/$defs/identifier"
        },
        "purpose": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "transit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keys": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/transitKey"
          }
        }
      }
    },
    "transitKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "allowed_operations"],
      "properties": {
        "type": {
          "enum": ["rsa-2048", "rsa-3072", "rsa-4096", "ecdsa-p256", "ed25519", "aes256-gcm96"]
        },
        "allowed_operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["sign", "verify", "encrypt", "decrypt", "read_public_key"]
          }
        },
        "rotation_period": {
          "$ref": "#/$defs/duration"
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engines": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/databaseEngine"
          }
        }
      }
    },
    "databaseEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin", "connection", "roles"],
      "properties": {
        "plugin": {
          "enum": ["postgresql", "mysql", "mariadb", "custom"]
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url_template", "admin_secret_ref"],
          "properties": {
            "url_template": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "admin_secret_ref": {
              "$ref": "#/$defs/identifier"
            },
            "verify_connection": {
              "type": "boolean"
            }
          }
        },
        "roles": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/databaseRole"
          }
        }
      }
    },
    "databaseRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_ttl", "max_ttl", "creation_statements", "revocation_statements"],
      "properties": {
        "default_ttl": {
          "$ref": "#/$defs/duration"
        },
        "max_ttl": {
          "$ref": "#/$defs/duration"
        },
        "grant_parent_role_ref": {
          "$ref": "#/$defs/identifier"
        },
        "creation_statements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "revocation_statements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engines": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/rabbitmqEngine"
          }
        }
      }
    },
    "rabbitmqEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connection", "roles"],
      "properties": {
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uri", "admin_secret_ref"],
          "properties": {
            "uri": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "admin_secret_ref": {
              "$ref": "#/$defs/identifier"
            },
            "verify_connection": {
              "type": "boolean"
            }
          }
        },
        "roles": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/rabbitmqRole"
          }
        }
      }
    },
    "rabbitmqRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_ttl", "max_ttl", "vhosts"],
      "properties": {
        "default_ttl": {
          "$ref": "#/$defs/duration"
        },
        "max_ttl": {
          "$ref": "#/$defs/duration"
        },
        "vhosts": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/rabbitmqPermissions"
          }
        }
      }
    },
    "rabbitmqPermissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configure", "write", "read"],
      "properties": {
        "configure": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "write": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "read": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "vso": {
      "type": "object",
      "additionalProperties": false,
      "required": ["auth_role", "static_syncs"],
      "properties": {
        "auth_role": {
          "$ref": "#/$defs/identifier"
        },
        "static_syncs": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/vsoStaticSync"
          }
        },
        "dynamic_syncs": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/vsoDynamicSync"
          }
        }
      }
    },
    "vsoStaticSync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kv_path_ref", "target"],
      "properties": {
        "kv_path_ref": {
          "$ref": "#/$defs/identifier"
        },
        "target": {
          "$ref": "#/$defs/kubernetesSecretTarget"
        },
        "rollout_restart_targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kubernetesWorkloadRef"
          }
        }
      }
    },
    "vsoDynamicSync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "role", "target"],
      "properties": {
        "engine": {
          "enum": ["database", "rabbitmq"]
        },
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "target": {
          "$ref": "#/$defs/kubernetesSecretTarget"
        },
        "rollout_restart_targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kubernetesWorkloadRef"
          }
        }
      }
    },
    "kubernetesSecretTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "name"],
      "properties": {
        "namespace": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "enum": ["Opaque", "kubernetes.io/dockerconfigjson", "kubernetes.io/tls", "custom"]
        }
      }
    },
    "kubernetesWorkloadRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "namespace", "name"],
      "properties": {
        "kind": {
          "enum": ["Deployment", "StatefulSet", "DaemonSet", "Job", "CronJob"]
        },
        "namespace": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "serviceConsumer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kubernetes_role_ref": {
          "$ref": "#/$defs/identifier"
        },
        "kv_path_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "transit_key_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "database_role_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "rabbitmq_role_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "credential_delivery": {
          "enum": ["spring_cloud_vault", "vault_agent", "vso_secret", "manual", "custom"]
        }
      }
    },
    "validationFixtures": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_checks": {
          "type": "array",
          "items": {
            "enum": ["auth_role_has_policy", "vso_kv_path_declared", "database_role_has_ttl", "rabbitmq_vhost_declared", "transit_key_declared", "no_secret_values"]
          }
        },
        "negative_cases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    }
  }
}
