{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.jorisjonkers.dev/deployment-sources.schema.json",
  "title": "JorisJonkers-dev Deployment Sources",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "deployment.jorisjonkers.dev/sources"
    },
    "kind": {
      "const": "DeploymentSources"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environments"
      ],
      "properties": {
        "environments": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "runtime",
              "development",
              "staging",
              "production"
            ]
          }
        },
        "firstParty": {
          "type": "object",
          "minProperties": 0,
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "bundle"
            ],
            "properties": {
              "bundle": {
                "type": "string",
                "minLength": 1
              },
              "repo": {
                "type": "string",
                "minLength": 1
              },
              "policy": {
                "enum": [
                  "locked",
                  "release"
                ]
              }
            }
          }
        },
        "collections": {
          "type": "object",
          "minProperties": 0,
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "repo",
              "ref"
            ],
            "properties": {
              "repo": {
                "type": "string",
                "minLength": 1
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "sha": {
                "type": "string",
                "pattern": "^[a-f0-9]{40}$"
              },
              "paths": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "hosts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repo",
            "ref"
          ],
          "properties": {
            "repo": {
              "type": "string",
              "minLength": 1
            },
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "paths": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "platformBlueprints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repo",
            "ref"
          ],
          "properties": {
            "repo": {
              "type": "string",
              "minLength": 1
            },
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "paths": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "policies": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
